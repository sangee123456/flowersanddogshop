@RequestMapping("client/orderitem")
public String orderitem(HttpSession ses,HttpServletRequest req) 
{
	String email=req.getParameter("email").toString();
	String mobile=req.getParameter("mobile").toString();
	String title=req.getParameter("title").toString();
	String desicription=req.getParameter("desicription").toString();
	String price=req.getParameter("price").toString();
	String offer=req.getParameter("offer").toString();
	String salesprice=req.getParameter("salesprice").toString();
	String neededqty=req.getParameter("neededqty").toString();
	String action=req.getParameter("action").toString();
	 int totalprice=Integer.parseInt(salesprice)*Integer.parseInt(neededqty);
	
	 Booked obj=new Booked();
	 obj.setEmail(email);
	 obj.setMobile(mobile);
	 obj.setTitle(title);
	 obj.setDesicription(desicription);
	 obj.setPrice(price);
	 obj.setOffer(offer);
	 obj.setSalesprice(salesprice);
	 obj.setNeededqty(neededqty);
	 obj.setAction(action);
	 obj.setTotalprice(totalprice);
	 bookedRepo.save(obj);
	 return "redirect:/client/bookingandsalesdetails";
}






