<div class="container mt-5">
<h1 style="text-align: center; color: blue;"></h1>
<div style=" padding: 30px;">

    <div class="text-center bg-white p-4 rounded shadow">

        <h1 style="font-weight:bold; color:#2e7d32; "class="img-hover1">
            🌸  FLOWERS OF NATURE AND FRIENDLY DOGS 🐕
        </h1>

        <p>Dogs • Birds • Rabbits • Fish</p>
        <p>Seeds • Flowers 
        </p>
<P>🌿</P>
<p><%
String mobile=session.getAttribute("mobile").toString();
 String email=session.getAttribute("email").toString();
out.print("Welcome!"+email);
%></p>
    </div>

</div>
