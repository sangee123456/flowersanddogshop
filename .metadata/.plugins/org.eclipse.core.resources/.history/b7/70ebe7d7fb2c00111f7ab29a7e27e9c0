<div>
<div class="container-fluid mt-3">
<%
   String urlid=session.getAttribute("urlid").toString();
   
   %>
<div class="container mt-4">
    <div class="row align-items-center">
        <c:forEach items="${sales}" var="d">
            <h2 class="text-center mb-4 text-uppercase">${d.title}</h2>
            <div style="display:flex; align-items: center; gap:5px">
                    <img src="/images/${d.title}.jpg" class="card-img-top" style="height: 200px;border-radius: 10px">
                    
                    <div class="card-body text-center">
                    <div class="col-md-8">
                        <h4 class="card-title text-primary">${d.saledetails}</h4> 
                        
                       <p class="card-text text-muted"><del>Price: ₹${d.price}</del></p>
                        
                        <div class="badge bg-warning text-dark mb-3">Offer: ${d.offerprice}%</div>
                        
                         <div class="badge bg-warning text-dark mb-3">Sales Price:             
                         
                          ${d.price*(d.offerprice/100)}</div>
                          </div>
                         <%--  <%
                             String email=session.getAttribute("email").toString();
                          out.println(email);
                           %>
                          --%>
                          
                        <form action="orderitem" method="post">
    
                        <input type="hidden" name="email" value="<%=email%>">
                        <input type="hidden" name="mobile" value="<%=mobile%>">
                        <input type="hidden" name="title" value="${d.title }">
                       <input type="hidden" name="desicription" value="${d.saledetails}">
                        <input type="hidden" name="price" value="${d.price}"> 
                       <input type=hidden name="offer" value="${d.offerprice}">
                       
                       <input type="hidden" name="salesprice" value="${Math.round(d.price * (d.offerprice / 100))}">
 
                    <input type=hidden name="action" value="booked">
                      <input type="number" name="neededqty" required="required" placeholder="neededqyt"> 
                        <button>Order Now</button>
                        </form>
                    </div>
                </div>
            </div>
        </c:forEach>
    </div>
</div>
</div>
