    pageEncoding="UTF-8"%> 
 <%@taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Nature flower and dogs</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>

<img src="../images/OIP.jpg" alt="dog" width="100%" height="250px">
<nav class="navbar navbar-expand-sm bg-dark navbar-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">Logo</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="collapsibleNavbar">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="http://localhost:8080/client/clientindex">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="bookingandsalesdetails">Booking and Sales Details</a>
        </li>
        <li>
         <a class="nav-link" href="logoutsession">Logout</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container mt-5">
<h1 style="text-align: center; color: blue;"></h1>
<div style=" padding: 30px;">

    <div class="text-center bg-white p-4 rounded shadow">

        <h1 style="font-weight:bold; color:#2e7d32; "class="img-hover1">
            🌸  FLOWERS OF NATURE AND FRIENDLY DOGS 🐕
        </h1>

        <p>Dogs • Birds • Rabbits • Fish</p>
        <p>Seeds • Flowers 
        </p>
<P>🌿</P>
<p><%
String mobile=session.getAttribute("mobile").toString();
 String email=session.getAttribute("email").toString();
out.print("Welcome!"+email);
%></p>
    </div>

</div>
</div>

<div>
<div class="container-fluid mt-3">
<%
   String urlid=session.getAttribute("urlid").toString();
   
   %>
<div class="container mt-5">
    <h2 class="text-center mb-4 text-uppercase">${urlid} Collections</h2>
    
    <div class="row">
        <c:forEach items="${sales}" var="d">
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <img src="/images/${d.title}.jpg" class="card-img-top" style="height: 200px; object-fit: cover;">
                    
                    <div class="card-body text-center">
                        <h4 class="card-title text-primary">${d.saledetails}</h4> 
                        
                       <p class="card-text text-muted"><del>Price: ₹${d.price}</del></p>
                        
                        <div class="badge bg-warning text-dark mb-3">Offer: ${d.offerprice}%</div>
                        
                         <div class="badge bg-warning text-dark mb-3">Sales Price:             
                         
                          ${d.price*(d.offerprice/100)}</div>
                          
                         <%--  <%
                             String email=session.getAttribute("email").toString();
                          out.println(email);
                           %>
                          --%>
                          
                        <form action="orderitem" method="post">
    
                        <input type=text name="email" value="<%=email%>"><br>
                        <input type=text name="mobile" value="<%=mobile%>"><br>
                        <input type=text name="title" value="${d.title }"> <br>
                       <input type=text name="desicription" value="${d.saledetails}"><br> 
                        <input type=text name="price" value="${d.price}"><br> 
                       <input type=text name="offer" value="${d.offerprice}"><br>
                       <input type="text" name="salesprice" value="${Math.round(d.price * (d.offerprice / 100))}">
 
 
                       <input type="number" name="neededqty" required="required"> 
                        <button>Order Now</button>
                        </form>
                    </div>
                </div>
            </div>
        </c:forEach>
    </div>
</div>
</div>
</div>
</body>
</html>